{
  "name": "release-change",
  "version": "0.5.3",
  "private": true,
  "description": "Fully automated version management, changelog management and package publishing with a focus on monorepos, pre-releases and major version zero",
  "keywords": [
    "automation",
    "changelog",
    "cli",
    "major-version-zero",
    "monorepo",
    "package",
    "pre-release",
    "publish",
    "release",
    "release-automation",
    "release-workflow",
    "semantic",
    "semantic-version",
    "semver",
    "semver-release",
    "tags",
    "version",
    "versioning"
  ],
  "homepage": "https://github.com/release-change/release-change",
  "bugs": {
    "url": "https://github.com/release-change/release-change/issues"
  },
  "author": "Victor Brito (https://victor-brito.dev)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/release-change/release-change.git"
  },
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "^22.12.0 || ^24.0.0",
    "npm": ">=10.9.0",
    "pnpm": ">=11.1.3"
  },
  "scripts": {
    "biome": "biome check --write .",
    "biome:check": "biome check .",
    "biome:format": "biome format --write .",
    "biome:format:check": "biome format .",
    "biome:lint": "biome lint --write .",
    "biome:lint:check": "biome lint .",
    "build": "tsc --build",
    "dev": "pnpm tsc:watch & pnpm test:watch",
    "prepare": "husky",
    "release-change": "packages/cli/bin/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "tsc:watch": "tsc --build --watch --preserveWatchOutput"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@types/node": "24.13.2",
    "husky": "9.1.7",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
